{
  "expo": {
    "name": "SpotD",
    "slug": "spotd-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spotd",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0d0d0d",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d0d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.suyashprabhu.spotd"
    },
    "android": {
      "package": "com.suyashprabhu.spotd",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0d0d0d"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#0d0d0d"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow SpotD to save music to your library.",
          "savePhotosPermission": "Allow SpotD to save files to your device.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
